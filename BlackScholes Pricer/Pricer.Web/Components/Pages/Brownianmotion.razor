@page "/brownian-motion"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-5">
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">Brownian Motion & Volatility</MudText>
    
    <MudGrid>
        <MudItem xs="12">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Instellingen (Diffusive Scaling)</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.body2">Aantal stappen (N): <b>@NumberOfSteps</b></MudText>
                            <MudSlider @bind-Value="NumberOfSteps" Min="10" Max="2000" Step="10" Color="Color.Primary" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.body2">
                                Volatiliteitsschaling (Alpha): <b>@ScalingExponent.ToString("F2")</b> 
                                <MudChip T="string" Size="Size.Small" Color="@GetChipColor()">@GetScalingDescription()</MudChip>
                            </MudText>
                            <MudSlider @bind-Value="ScalingExponent" Min="0.1" Max="0.9" Step="0.05" Color="Color.Secondary" />
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateData" Class="ml-auto">
                        Genereer Nieuw Pad
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <MudItem xs="12">
            <MudCard Elevation="3" Class="pa-4">
                <MudChart ChartType="ChartType.Line" ChartSeries="@_series" Width="100%" Height="400px" ChartOptions="@_options" />
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private int _numberOfSteps = 500;
    public int NumberOfSteps 
    { 
        get => _numberOfSteps; 
        set { _numberOfSteps = value; GenerateData(); } 
    }

    private double _scalingExponent = 0.5;
    public double ScalingExponent 
    { 
        get => _scalingExponent; 
        set { _scalingExponent = value; GenerateData(); } 
    }

    private List<ChartSeries<double>> _series = new();
    
    // DisableLegend verwijderd om de error op te lossen
    private ChartOptions _options = new ChartOptions();

    protected override void OnInitialized()
    {
        GenerateData();
    }

    private void GenerateData()
    {
        var random = new Random();
        
        double dt = 1.0 / NumberOfSteps;
        double dx = Math.Pow(dt, ScalingExponent); 

        double[] data = new double[NumberOfSteps + 1];
        
        data[0] = 0.0;

        for (int i = 1; i <= NumberOfSteps; i++)
        {
            double stepDirection = random.NextDouble() >= 0.5 ? 1.0 : -1.0;
            data[i] = data[i - 1] + stepDirection * dx;
        }

        _series = new List<ChartSeries<double>>
        {
            new ChartSeries<double> { Name = "Stochastisch Pad", Data = data }
        };
        
        InvokeAsync(StateHasChanged);
    }

    private string GetScalingDescription()
    {
        if (Math.Abs(ScalingExponent - 0.5) < 0.01) return "Brownian Motion";
        if (ScalingExponent < 0.5) return "Explosion";
        return "Freezing";
    }

    private Color GetChipColor()
    {
        if (Math.Abs(ScalingExponent - 0.5) < 0.01) return Color.Success;
        if (ScalingExponent < 0.5) return Color.Error;
        return Color.Info;
    }
}