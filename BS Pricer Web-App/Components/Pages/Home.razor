@page "/"

@using BS_Calculator

<h3>Black-Scholes Option Pricer</h3>

<div>
    <label>Underlying Price (S):</label>
    <input type="number" @bind="S" />
</div>

<div>
    <label>Strike (K):</label>
    <input type="number" @bind="K" />
</div>

<div>
    <label>Risk-free rate (r):</label>
    <input type="number" step="0.01" @bind="r" />
</div>

<div>
    <label>Time to maturity (years):</label>
    <input type="number" step="0.01" @bind="T" />
</div>

<div>
    <label>Volatility (σ):</label>
    <input type="number" step="0.01" @bind="sigma" />
</div>

<div>
    <label>Option Type:</label>
    <select @bind="SelectedType">
        <option value="Call">Call</option>
        <option value="Put">Put</option>
    </select>
</div>

<button @onclick="CalculatePrice">
    Calculate Option Price
</button>

@if (Price != null)
{
    <h4>Option Price: @Price.Value.ToString("F4")</h4>
}

@code {
    double S;
    double K;
    double r;
    double T;
    double sigma;

    OptionType SelectedType = OptionType.Call;

    double? Price;

    void CalculatePrice()
    {
        Price = BlackScholes.Calculate(S, K, r, T, sigma, SelectedType);
    }
}